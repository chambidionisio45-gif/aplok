{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "trenbankai:smoke_grenade",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/particle/smoke/smoke"
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": {
        "num_particles": "math.random_integer(4, 14)"
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.1
      },
      "minecraft:emitter_shape_sphere": {
        "radius": 4,
        "surface_only": true,
        "direction": ["math.random(-0.5, 0.5)", 1, "math.random(-0.5, 0.5)"]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": 1
      },
      "minecraft:particle_expire_if_not_in_blocks": ["minecraft:air"],
      "minecraft:particle_initial_spin": {
        "rotation": "math.random(-180, 180)"
      },
      "minecraft:particle_initial_speed": 1,
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [0.1, 2, 0.1],
        "linear_drag_coefficient": 2
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "2.5 - (v.particle_age * v.particle_lifetime)",
          "2.5 - (v.particle_age * v.particle_lifetime)"
        ],
        "facing_camera_mode": "rotate_xyz",
        "uv": {
          "texture_width": 16,
          "texture_height": 128,
          "flipbook": {
            "base_UV": [0, 0],
            "size_UV": [16, 16],
            "step_UV": [0, 16],
            "frames_per_second": 12,
            "max_frame": 8,
            "stretch_to_lifetime": true
          }
        }
      },
      "minecraft:particle_appearance_lighting": {},
      "minecraft:particle_appearance_tinting": {
        "color": [
          1,
          1,
          1,
          "math.clamp(0.5 - math.clamp(v.particle_age / v.particle_lifetime, 0, 1), 0, 0.5)"
        ]
      }
    }
  }
}
