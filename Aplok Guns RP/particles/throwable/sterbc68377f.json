{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "trenbankai:flare_smoke",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/particle/smoke/flare_smoke"
      }
    },
    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 5,
        "max_particles": 10
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 1
      },
      "minecraft:emitter_shape_point": {
        "offset": [0, 0.15, 0.15],
        "direction": ["Math.random(-0.5, 0.5)", -0.25, -0.5]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "Math.random(2, 16)"
      },
      "minecraft:particle_initial_spin": {
        "rotation": "math.random(-180, 180)",
        "rotation_rate": "math.random(-25, 25)"
      },
      "minecraft:particle_initial_speed": 2,
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": ["Math.random(-2, 2)", 2, "Math.random(-5, 5)"]
      },
      "minecraft:particle_appearance_billboard": {
        "size": ["0.5 + v.particle_age", "0.5 + v.particle_age"],
        "facing_camera_mode": "rotate_xyz",
        "uv": {
          "texture_width": 8,
          "texture_height": 80,
          "flipbook": {
            "base_UV": [0, 0],
            "size_UV": [8, 8],
            "step_UV": [0, 8],
            "frames_per_second": 6,
            "max_frame": 10
          }
        }
      },
      "minecraft:particle_motion_collision": {
        "collision_radius": 0.01,
        "expire_on_contact": true
      },
      "minecraft:particle_appearance_lighting": {},
      "minecraft:particle_appearance_tinting": {
        "color": [
          1,
          1,
          1,
          "math.clamp(1 - math.clamp(v.particle_age / v.particle_lifetime, 0, 1), 0, 1)"
        ]
      }
    }
  }
}
