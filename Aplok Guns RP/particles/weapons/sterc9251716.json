{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "trenbankai:muzzle_spark",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/misc/spark"
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": {
        "num_particles": 4
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.1
      },
      "minecraft:emitter_shape_point": {
        "direction": ["math.random(-5, 5)", "math.random(-5, 5)", -5]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": 0.4
      },
      "minecraft:particle_expire_if_not_in_blocks": ["minecraft:air"],
      "minecraft:particle_initial_speed": "math.random(0, 10)",
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [0, -4, 0],
        "linear_drag_coefficient": 6
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "0.1 * (0.3 - v.particle_age)",
          "0.01 * (0.3 - v.particle_age)"
        ],
        "facing_camera_mode": "lookat_direction",
        "uv": {
          "texture_width": 2,
          "texture_height": 2,
          "uv": [0, 0],
          "uv_size": [2, 2]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "v.particle_age / v.particle_lifetime",
          "gradient": {
            "0.0": "#FFFFF5AA",
            "0.22": "#ffffffff",
            "0.4": "#FFFF8B71"
          }
        }
      }
    }
  }
}
