{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "trenbankai:bullet_spark",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/misc/spark"
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": {
        "num_particles": 8
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.1
      },
      "minecraft:emitter_shape_sphere": {
        "radius": 0.05,
        "surface_only": true,
        "direction": "outwards"
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": 0.4
      },
      "minecraft:particle_expire_if_in_blocks": [
        "minecraft:water",
        "minecraft:flowing_water"
      ],
      "minecraft:particle_initial_speed": "math.random(0, 10)",
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [0, -9.807, 0],
        "linear_drag_coefficient": 6
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "0.2 * (0.4 - v.particle_age)",
          "0.02 * (0.4 - v.particle_age)"
        ],
        "facing_camera_mode": "lookat_direction",
        "uv": {
          "texture_width": 2,
          "texture_height": 2,
          "uv": [0, 0],
          "uv_size": [2, 2]
        }
      },
      "minecraft:particle_motion_collision": {
        "collision_drag": 1,
        "coefficient_of_restitution": 0.2,
        "collision_radius": 0.01
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "v.particle_age / v.particle_lifetime",
          "gradient": {
            "0.0": "#FFFFF5AA",
            "0.22": "#ffffffff",
            "0.4": "#FFFF8B71"
          }
        }
      }
    }
  }
}
