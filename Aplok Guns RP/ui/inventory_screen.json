{
  "namespace": "crafting",
  "crafting_panel_top_half": {
    "type": "panel",
    "size": ["100%", "50%"],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "controls": [
      {
        "crafting_panel@crafting.work_bench_panel_3x3": {
          "offset": [29, 0],
          "bindings": [
            {
              "binding_name": "#crafting_label_text",
              "binding_type": "global"
            },
            {
              "binding_type": "view",
              "source_property_name": "(not (#crafting_label_text = 'ui.weapon_workbench'))",
              "target_property_name": "#visible"
            }
          ]
        }
      },
      {
        "workbench_panel@workbench.workbench_panel": {
          "offset": [29, 0],
          "bindings": [
            {
              "binding_name": "#crafting_label_text",
              "binding_type": "global"
            },
            {
              "binding_type": "view",
              "source_property_name": "(#crafting_label_text = 'ui.weapon_workbench')",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  }
}
