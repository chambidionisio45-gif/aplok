        "hud_noise": "geometry.hud_noise",
        "hud_sight": "geometry.hud_sight"
      },
      "scripts": {
        "should_update_effects_offscreen": true,
        "scale": "0.9375",
        "initialize": [
          "v.is_holding_right = 0;",
          "v.is_blinking = 0;",
          "v.last_blink_time = 0;",
          "v.hand_bob = 0;",
          // Misc
          "v.is_ui = 0;",
          // Locators
          "v.muzzle_offset.x = 0;",
          "v.muzzle_offset.y = 0;",
          "v.muzzle_offset.z = 0;",
          "v.buttstock_offset.x = 0;",
          "v.buttstock_offset.y = 0;",
          "v.buttstock_offset.z = 0;",
          "v.bulleteject_offset.x = 0;",
          "v.bulleteject_offset.y = 0;",
          "v.bulleteject_offset.z = 0;",
          // Recoil
          "v.recoil.x = 0;",
          "v.recoil.y = 0;",
          "v.recoil.z = 0;"
        ],
        "pre_animation": [
          "v.helmet_layer_visible = !q.has_head_gear;",
          "v.leg_layer_visible = 1;",
          "v.boot_layer_visible = 1;",
          "v.chest_layer_visible = 1;",
          "v.attack_body_rot_y = math.sin(360 * math.sqrt(v.attack_time)) * 5;",
          "v.tcos0 = (math.cos(q.modified_distance_moved * 38.17) * q.modified_move_speed / v.gliding_speed_value) * 57.3;",
          "v.first_person_rotation_factor = math.sin((1 - v.attack_time) * 180);",
          "v.hand_bob = q.life_time < 0.01 ? 0 : v.hand_bob + ((q.is_on_ground && q.is_alive ? math.clamp(math.sqrt(math.pow(q.position_delta(0), 2) + math.pow(q.position_delta(2), 2)), 0, 0.1) : 0) - v.hand_bob) * 0.02;",
          "v.map_angle = math.clamp(1 - v.player_x_rotation / 45.1, 0, 1);",
          "v.item_use_normalized = q.main_hand_item_use_duration / q.main_hand_item_max_duration;",
          "v.riding_y_offset = q.is_riding_any_entity_of_type('minecraft:minecart', 'minecraft:boat', 'minecraft:chest_boat', 'minecraft:strider') ? -3 : 0;",
          // Weapons
          "v.crawling = q.is_crawling;",
          "v.weapons = q.equipped_item_all_tags('slot.weapon.mainhand', 'is_weapon');",
          "v.reloading = q.property('trenbankai:reload');",
          "v.cycling = q.property('trenbankai:cycle');",
          "v.standby = q.property('trenbankai:standby') || v.crawling;",
          "v.wall_detect = q.property('trenbankai:wall_detect');",
          "v.firing = q.main_hand_item_use_duration;",
          "v.draw = !q.is_sleeping && !q.is_emoting && !q.is_swimming && !q.is_crawling && q.is_alive;",
          "v.aiming = q.is_sneaking && !v.reloading && !v.wall_detect;",
          "v.running = q.is_sprinting && !v.aiming && !v.firing && !v.reloading;",
          "v.look_at_target = v.weapons && !v.running && !v.standby && !q.is_riding;",
          "v.bipod_phisycs = (v.reloading || v.standby || v.running) ? 0 : math.clamp(-q.target_x_rotation, -50, 50);",
          // Attachments
          "v.weapon_grip = q.property('trenbankai:grip');",
          "v.weapon_laser = q.property('trenbankai:laser');",
          "v.weapon_sight = q.property('trenbankai:sight');",
          "v.weapon_silencer = q.property('trenbankai:silencer');",
          // General
          "v.helmet_visible = !q.equipped_item_all_tags('slot.armor.head', 'is_helmet');",
          "v.chest_visible = !q.equipped_item_all_tags('slot.armor.head', 'is_chest');",
          "v.leg_visible = !q.equipped_item_all_tags('slot.armor.head', 'is_leg');",
          "v.boot_visible = !q.equipped_item_all_tags('slot.armor.head', 'is_boot');",
          "v.is_third_person = !v.is_first_person && !v.map_face_icon;",
          "v.is_ui = q.is_in_ui && v.is_paperdoll;",
          // General
          "v.throwable = q.equipped_item_all_tags('slot.weapon.mainhand', 'is_throwable');",
          "v.threeditem = v.throwable || v.weapons;",
          // HUD
          "v.hud_sight = v.weapons && (v.weapon_sight == 4 || v.weapon_sight == 5) && !v.wall_detect && !v.reloading;"
        ],
        "animate": ["core", "weapons_controller"]
      },
